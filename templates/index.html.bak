<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MolSim - Análise de Similaridade Molecular</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #0f1419 0%, #1a2a3a 50%, #0f1419 100%);
            background-attachment: fixed;
            min-height: 100vh;
            color: #ffffff;
            position: relative;
            overflow-x: hidden;
        }

        /* Padrão geométrico de fundo */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(0, 255, 255, 0.03) 35px, rgba(0, 255, 255, 0.03) 70px);
            pointer-events: none;
            z-index: 0;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
            position: relative;
            z-index: 1;
        }

        header {
            text-align: center;
            margin-bottom: 50px;
            animation: slideDown 0.6s ease-out;
        }

        header h1 {
            font-size: 3.5em;
            font-weight: 700;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #00ffff, #00ff00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -1px;
        }

        header p {
            font-size: 1.2em;
            color: #a0aec0;
            font-weight: 300;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .card {
            background: linear-gradient(135deg, rgba(26, 42, 58, 0.8) 0%, rgba(15, 20, 25, 0.8) 100%);
            border: 2px solid #00ffff;
            border-radius: 12px;
            padding: 30px;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px rgba(0, 255, 255, 0.1);
            transition: all 0.3s ease;
            animation: fadeInUp 0.6s ease-out;
        }

        .card:hover {
            border-color: #00ff00;
            box-shadow: 0 12px 48px rgba(0, 255, 0, 0.15);
            transform: translateY(-5px);
        }

        .card h2 {
            font-size: 1.3em;
            margin-bottom: 20px;
            color: #00ffff;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.95em;
            color: #cbd5e0;
            font-weight: 500;
        }

        input[type="text"],
        select {
            width: 100%;
            padding: 12px 15px;
            background: rgba(15, 20, 25, 0.6);
            border: 2px solid #00ffff;
            border-radius: 8px;
            color: #ffffff;
            font-size: 0.95em;
            transition: all 0.3s ease;
            font-family: 'Courier New', monospace;
        }

        input[type="text"]::placeholder,
        select {
            color: #718096;
        }

        input[type="text"]:focus,
        select:focus {
            outline: none;
            border-color: #00ff00;
            box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
            background: rgba(15, 20, 25, 0.8);
        }

        select {
            cursor: pointer;
            padding: 12px 15px;
        }

        select option {
            background: #1a2a3a;
            color: #ffffff;
        }

        .button-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 25px;
        }

        button {
            padding: 14px 24px;
            background: linear-gradient(135deg, #00ffff 0%, #00ff00 100%);
            color: #000000;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 255, 0, 0.3);
        }

        button:active {
            transform: translateY(-1px);
        }

        .results {
            background: linear-gradient(135deg, rgba(26, 42, 58, 0.9) 0%, rgba(15, 20, 25, 0.9) 100%);
            border: 2px solid #00ff00;
            border-radius: 12px;
            padding: 40px;
            display: none;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px rgba(0, 255, 0, 0.1);
            animation: slideUp 0.6s ease-out;
        }

        .results.show {
            display: block;
        }

        .result-header {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid rgba(0, 255, 255, 0.3);
        }

        .metric {
            text-align: center;
            padding: 20px;
            background: rgba(0, 255, 255, 0.05);
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .metric:hover {
            background: rgba(0, 255, 0, 0.05);
            border-color: rgba(0, 255, 0, 0.4);
        }

        .metric-label {
            font-size: 0.85em;
            color: #a0aec0;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .metric-value {
            font-size: 2.2em;
            font-weight: 700;
            background: linear-gradient(135deg, #00ffff, #00ff00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .structures {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .structure {
            background: rgba(0, 255, 255, 0.05);
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 8px;
            padding: 20px;
            text-align: center;
        }

        .structure h3 {
            color: #00ffff;
            margin-bottom: 15px;
            font-size: 1.2em;
        }

        .structure svg {
            max-width: 100%;
            height: auto;
            filter: drop-shadow(0 0 10px rgba(0, 255, 255, 0.2));
        }

        h3 {
            font-size: 1.5em;
            margin-bottom: 20px;
            margin-top: 30px;
            color: #00ff00;
            font-weight: 600;
        }

        h3:first-of-type {
            margin-top: 0;
        }

        .properties-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            background: rgba(0, 255, 255, 0.03);
            border-radius: 8px;
            overflow: hidden;
        }

        .properties-table th {
            background: linear-gradient(135deg, rgba(0, 255, 255, 0.2) 0%, rgba(0, 255, 0, 0.1) 100%);
            color: #00ffff;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            border-bottom: 2px solid rgba(0, 255, 255, 0.3);
            text-transform: uppercase;
            font-size: 0.85em;
            letter-spacing: 1px;
        }

        .properties-table td {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(0, 255, 255, 0.1);
            color: #cbd5e0;
        }

        .properties-table tr:hover {
            background: rgba(0, 255, 255, 0.05);
        }

        .properties-table tr:nth-child(even) {
            background: rgba(0, 255, 255, 0.02);
        }

        .chart-container {
            position: relative;
            width: 100%;
            height: 350px;
            margin-bottom: 30px;
            background: rgba(0, 255, 255, 0.02);
            border: 1px solid rgba(0, 255, 255, 0.1);
            border-radius: 8px;
            padding: 15px;
        }

        #logd-chart {
            width: 100% !important;
            height: 100% !important;
        }

        .export-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #00ff00 0%, #00ffff 100%);
            color: #000000;
            border: none;
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        .export-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(0, 255, 0, 0.4);
        }

        .error {
            background: rgba(255, 0, 0, 0.1);
            border: 2px solid #ff4444;
            color: #ff8888;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
            animation: shake 0.3s ease-in-out;
        }

        .error.show {
            display: block;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 40px;
        }

        .loading.show {
            display: block;
        }

        .spinner {
            border: 4px solid rgba(0, 255, 255, 0.2);
            border-top: 4px solid #00ffff;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }

        @media (max-width: 768px) {
            .content {
                grid-template-columns: 1fr;
            }

            .structures {
                grid-template-columns: 1fr;
            }

            .result-header {
                grid-template-columns: 1fr;
            }

            header h1 {
                font-size: 2.5em;
            }

            .button-group {
                grid-template-columns: 1fr;
            }

            .chart-container {
                height: 300px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>🧬 MolSim</h1>
            <p>Análise Profissional de Similaridade Molecular</p>
        </header>

        <div class="content">
            <div class="card">
                <h2>Molécula Referência</h2>
                <div class="form-group">
                    <label for="smiles-ref">SMILES</label>
                    <input type="text" id="smiles-ref" placeholder="Ex: CC(=O)OC1=CC=CC=C1C(=O)O">
                </div>
                <div class="form-group">
                    <label for="name-ref">Nome (opcional)</label>
                    <input type="text" id="name-ref" placeholder="Ex: Aspirina">
                </div>
            </div>

            <div class="card">
                <h2>Molécula Teste</h2>
                <div class="form-group">
                    <label for="smiles-test">SMILES</label>
                    <input type="text" id="smiles-test" placeholder="Ex: CC(=O)NC1=CC=C(O)C=C1">
                </div>
                <div class="form-group">
                    <label for="name-test">Nome (opcional)</label>
                    <input type="text" id="name-test" placeholder="Ex: Paracetamol">
                </div>
            </div>
        </div>

        <div class="content">
            <div class="card">
                <h2>Fingerprint</h2>
                <div class="form-group">
                    <label for="fingerprint">Tipo</label>
                    <select id="fingerprint">
                        <option value="Morgan2 ECFP">Morgan2 ECFP (Raio 2, 2048 bits)</option>
                        <option value="Morgan2 FCFP">Morgan2 FCFP (Raio 2, 2048 bits)</option>
                        <option value="RDKit">RDKit Topológico</option>
                        <option value="MACCS">MACCS Keys (166 bits)</option>
                    </select>
                </div>
            </div>

            <div class="card">
                <h2>Métrica de Similaridade</h2>
                <div class="form-group">
                    <label for="metric">Tipo</label>
                    <select id="metric">
                        <option value="Tanimoto">Tanimoto</option>
                        <option value="Dice">Dice</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="button-group">
                <button onclick="analisarMoleculas()">🔍 Analisar</button>
                <button onclick="limparCampos()" style="background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);">🔄 Limpar</button>
            </div>
        </div>

        <div class="error" id="error"></div>
        <div class="loading" id="loading"><div class="spinner"></div></div>

        <div class="results" id="results">
            <div class="result-header">
                <div class="metric">
                    <div class="metric-label">Similaridade</div>
                    <div class="metric-value" id="similarity"></div>
                </div>
                <div class="metric">
                    <div class="metric-label">Classificação</div>
                    <div class="metric-value" id="classification"></div>
                </div>
                <div class="metric">
                    <div class="metric-label">Método</div>
                    <div style="font-size: 0.9em; color: #a0aec0; line-height: 1.4; margin-top: 5px;" id="method"></div>
                </div>
            </div>

            <div class="structures" id="structures"></div>

            <h3>Propriedades Físico-Químicas</h3>
            <table class="properties-table" id="properties-table"></table>

            <h3>LogD vs pH (Coeficiente de Lipofilicidade)</h3>
            <div class="chart-container">
                <canvas id="logd-chart"></canvas>
            </div>

            <button class="export-btn" onclick="exportarPDF()">📥 Exportar PDF</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        let lastResult = null;
        let logdChart = null;

        async function analisarMoleculas() {
            const smilesRef = document.getElementById('smiles-ref').value.trim();
            const smilesTest = document.getElementById('smiles-test').value.trim();
            const nameRef = document.getElementById('name-ref').value.trim() || 'Molécula Referência';
            const nameTest = document.getElementById('name-test').value.trim() || 'Molécula Teste';
            const fingerprint = document.getElementById('fingerprint').value;
            const metric = document.getElementById('metric').value;

            if (!smilesRef || !smilesTest) {
                mostrarErro('Por favor, insira SMILES válidos para ambas as moléculas');
                return;
            }

            limparErro();
            mostrarCarregamento(true);

            try {
                const response = await fetch('/compare', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        smiles_ref: smilesRef,
                        smiles_test: smilesTest,
                        name_ref: nameRef,
                        name_test: nameTest,
                        fp_type: fingerprint,
                        metric: metric
                    })
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.error || 'Erro ao processar moléculas');
                }

                const result = await response.json();
                lastResult = result;
                exibirResultados(result, fingerprint, metric, nameRef, nameTest);
            } catch (error) {
                mostrarErro(error.message);
            } finally {
                mostrarCarregamento(false);
            }
        }

        function exibirResultados(result, fp_type, metric, name_ref, name_test) {
            document.getElementById('similarity').textContent = result.similarity.toFixed(4);
            document.getElementById('classification').textContent = result.classification;
            
            let methodText = fp_type;
            if (fp_type === 'Morgan2 ECFP') {
                methodText = 'Morgan2 ECFP<br/>(Raio 2, 2048 bits)<br/>Extended Connectivity';
            } else if (fp_type === 'Morgan2 FCFP') {
                methodText = 'Morgan2 FCFP<br/>(Raio 2, 2048 bits)<br/>Feature-based';
            } else if (fp_type === 'MACCS') {
                methodText = 'MACCS Keys<br/>(166 bits)';
            }
            methodText += `<br/>${metric}`;
            document.getElementById('method').innerHTML = methodText;

            const structuresDiv = document.getElementById('structures');
            structuresDiv.innerHTML = `
                <div class="structure">
                    <h3>${name_ref}</h3>
                    ${result.svg_ref}
                </div>
                <div class="structure">
                    <h3>${name_test}</h3>
                    ${result.svg_test}
                </div>
            `;

            const table = document.getElementById('properties-table');
            table.innerHTML = `
                <tr>
                    <th>Propriedade</th>
                    <th>${name_ref}</th>
                    <th>${name_test}</th>
                    <th>Diferença</th>
                </tr>
                ${result.properties.map(p => `
                    <tr>
                        <td>${p.Propriedade}</td>
                        <td>${p.Referência}</td>
                        <td>${p.Teste}</td>
                        <td>${p.Diferença}</td>
                    </tr>
                `).join('')}
            `;

            // Aguardar um pouco para o DOM estar pronto
            setTimeout(() => {
                desenharGraficoLogD(result.logd_ref, result.logd_test, name_ref, name_test);
            }, 100);

            document.getElementById('results').classList.add('show');
        }

        function desenharGraficoLogD(logd_ref, logd_test, name_ref, name_test) {
            try {
                const canvas = document.getElementById('logd-chart');
                if (!canvas) {
                    console.error('Canvas não encontrado');
                    return;
                }

                const ctx = canvas.getContext('2d');
                
                if (logdChart) {
                    logdChart.destroy();
                    logdChart = null;
                }
                
                const ph_values = logd_ref.map(d => d.pH);
                const logd_ref_values = logd_ref.map(d => d.LogD);
                const logd_test_values = logd_test.map(d => d.LogD);
                
                logdChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ph_values,
                        datasets: [
                            {
                                label: name_ref,
                                data: logd_ref_values,
                                borderColor: '#00ffff',
                                backgroundColor: 'rgba(0, 255, 255, 0.1)',
                                borderWidth: 3,
                                pointRadius: 4,
                                pointBackgroundColor: '#00ffff',
                                pointBorderColor: '#0f1419',
                                pointBorderWidth: 2,
                                tension: 0.4,
                                fill: true
                            },
                            {
                                label: name_test,
                                data: logd_test_values,
                                borderColor: '#00ff00',
                                backgroundColor: 'rgba(0, 255, 0, 0.1)',
                                borderWidth: 3,
                                pointRadius: 4,
                                pointBackgroundColor: '#00ff00',
                                pointBorderColor: '#0f1419',
                                pointBorderWidth: 2,
                                tension: 0.4,
                                fill: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                                labels: {
                                    font: { size: 12, weight: 'bold' },
                                    padding: 15,
                                    usePointStyle: true,
                                    color: '#cbd5e0'
                                }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(15, 20, 25, 0.95)',
                                padding: 12,
                                titleFont: { size: 12, weight: 'bold' },
                                bodyFont: { size: 11 },
                                borderColor: '#00ffff',
                                borderWidth: 1,
                                callbacks: {
                                    label: function(context) {
                                        return context.dataset.label + ': ' + context.parsed.y.toFixed(3);
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                title: {
                                    display: true,
                                    text: 'pH',
                                    font: { size: 12, weight: 'bold' },
                                    color: '#00ffff'
                                },
                                grid: {
                                    color: 'rgba(0, 255, 255, 0.1)'
                                },
                                ticks: {
                                    color: '#a0aec0'
                                }
                            },
                            y: {
                                title: {
                                    display: true,
                                    text: 'LogD',
                                    font: { size: 12, weight: 'bold' },
                                    color: '#00ff00'
                                },
                                grid: {
                                    color: 'rgba(0, 255, 0, 0.1)'
                                },
                                ticks: {
                                    color: '#a0aec0'
                                }
                            }
                        }
                    }
                });
            } catch (error) {
                console.error('Erro ao desenhar gráfico:', error);
            }
        }

        async function exportarPDF() {
            if (!lastResult) return;

            const element = document.getElementById('results');
            const opt = {
                margin: 10,
                filename: 'molsim-analise.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, backgroundColor: '#0f1419' },
                jsPDF: { orientation: 'portrait', unit: 'mm', format: 'a4' }
            };

            html2pdf().set(opt).from(element).save();
        }

        function limparCampos() {
            document.getElementById('smiles-ref').value = '';
            document.getElementById('smiles-test').value = '';
            document.getElementById('name-ref').value = '';
            document.getElementById('name-test').value = '';
            document.getElementById('results').classList.remove('show');
            limparErro();
        }

        function mostrarErro(mensagem) {
            const errorDiv = document.getElementById('error');
            errorDiv.textContent = '⚠️ ' + mensagem;
            errorDiv.classList.add('show');
        }

        function limparErro() {
            document.getElementById('error').classList.remove('show');
        }

        function mostrarCarregamento(show) {
            document.getElementById('loading').classList.toggle('show', show);
        }
    </script>
</body>
</html>
